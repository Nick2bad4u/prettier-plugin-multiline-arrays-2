{
    "name": "prettier-plugin-multiline-arrays",
    "version": "4.1.9",
    "description": "Prettier plugin to force all arrays to be multiline.",
    "keywords": [
        "array",
        "format",
        "multiline",
        "plugin",
        "prettier",
        "printer"
    ],
    "homepage": "https://github.com/electrovir/prettier-plugin-multiline-arrays",
    "bugs": {
        "url": "https://github.com/electrovir/prettier-plugin-multiline-arrays/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/electrovir/prettier-plugin-multiline-arrays.git"
    },
    "license": "(MIT OR CC0-1.0)",
    "author": {
        "name": "electrovir",
        "url": "https://github.com/electrovir"
    },
    "sideEffects": false,
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "compile": "virmator compile",
        "docs": "virmator docs",
        "format": "virmator format --no-deps",
        "lint": "virmator lint fix",
        "publish": "virmator publish npm run test:all",
        "test": "test-as-package virmator test node",
        "test:all": "npm run compile && npm run test:versions && runstorm --names spelling,format,deps,lint \"npm run test:spelling\" \"npm run test:format\" \"npm run test:deps\" \"npm run test:lint\"",
        "test:deps": "virmator deps check",
        "test:docs": "virmator docs check",
        "test:format": "virmator format check --no-deps",
        "test:lint": "virmator lint",
        "test:spelling": "virmator spellcheck",
        "test:update": "npm run test update",
        "test:versions": "npm run compile && npx tsx src/test/prettier-versions.mock.script.ts"
    },
    "dependencies": {
        "@augment-vir/assert": "^31.71.3",
        "@augment-vir/common": "^31.71.3",
        "proxy-vir": "^2.0.2"
    },
    "devDependencies": {
        "@augment-vir/node": "^31.71.3",
        "@augment-vir/test": "^31.71.3",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.2",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@stylistic/eslint-plugin-ts": "^4.4.1",
        "@types/esprima": "^4.0.6",
        "@types/estree": "^1.0.9",
        "@types/node": "^25.9.1",
        "@types/semver": "^7.7.1",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@virmator/format": "^14.19.1",
        "c8": "^11.0.0",
        "cross-env": "^10.1.0",
        "cspell": "^10.0.0",
        "dependency-cruiser": "^17.4.3",
        "esbuild": "^0.28.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^63.0.0",
        "eslint-plugin-monorepo-cop": "^1.0.2",
        "eslint-plugin-playwright": "^2.10.4",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-require-extensions": "^0.1.3",
        "eslint-plugin-sonarjs": "^4.0.3",
        "eslint-plugin-unicorn": "^64.0.0",
        "istanbul-smart-text-reporter": "^1.1.5",
        "markdown-code-example-inserter": "^3.0.5",
        "npm-check-updates": "^22.2.1",
        "object-shape-tester": "^6.13.0",
        "prettier": "3.3.3",
        "prettier-plugin-interpolated-html-tags": "^2.0.1",
        "prettier-plugin-jsdoc": "^1.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-packagejson": "^3.0.2",
        "prettier-plugin-sort-json": "^4.2.0",
        "prettier-plugin-toml": "^2.0.6",
        "runstorm": "^1.0.2",
        "semver": "^7.8.1",
        "test-as-package": "^2.0.4",
        "tsx": "^4.22.3",
        "type-fest": "^5.6.0",
        "typedoc": "^0.28.19",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1",
        "virmator": "^14.19.1"
    },
    "peerDependencies": {
        "prettier": ">=3.0.0 <4.0.0"
    },
    "engines": {
        "node": ">=20"
    }
}
